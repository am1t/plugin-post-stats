{
    "version": "2.0.0",
    "title": "Posts Stats",
    "description": "Displays stats about published posts",
    "includes": [
        "/assets/css/poststats.css",
        "/assets/js/poststats.js"
    ],
    "fields": [
		{
			"field": "params.disable_year_recap",
			"label": "Remove Year Recap section from the stats page",
			"type": "boolean"
		},
		{
			"field": "params.use_legacy_stats",
			"label": "Use the original minimal stats layout instead of the revamped design",
			"type": "boolean"
		}
	]
  }